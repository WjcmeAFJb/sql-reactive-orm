{
  "name": "sql-reactive-orm",
  "version": "0.1.0",
  "description": "Reactive ORM for SQLite, built on MobX. Fields and relations are Promises that hydrate on first read — usable directly with React `use` / Suspense.",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./drivers/sqljs": "./src/drivers/sqljs.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:node": "vitest run --project node",
    "test:browser": "vitest run --project browser",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "mobx": "^6.13.5"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sql.js": "^1.12.0"
  },
  "peerDependenciesMeta": {
    "sql.js": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/sql.js": "^1.4.9",
    "@vitest/browser": "^4.1.4",
    "@vitest/browser-playwright": "^4.1.4",
    "mobx-react-lite": "^4.0.7",
    "playwright": "^1.49.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sql.js": "^1.12.0",
    "typescript": "^5.7.2",
    "vite": "^6.4.2",
    "vitest": "^4.1.4",
    "vitest-browser-react": "^2.2.0"
  }
}
