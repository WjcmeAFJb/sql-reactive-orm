{
  "name": "sql-reactive-orm",
  "version": "0.2.0",
  "description": "Reactive ORM for SQLite, built on MobX. Fields and relations are Promises that hydrate on first read — usable directly with React `use` / Suspense.",
  "license": "LGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/WjcmeAFJb/sql-reactive-orm.git"
  },
  "homepage": "https://WjcmeAFJb.github.io/sql-reactive-orm/",
  "keywords": [
    "sqlite",
    "orm",
    "reactive",
    "mobx",
    "react",
    "suspense",
    "kysely",
    "sqljs",
    "sql-git"
  ],
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./drivers/sqljs": "./src/drivers/sqljs.ts"
  },
  "files": [
    "src",
    "LICENSE",
    "COPYING",
    "COPYING.LESSER",
    "README.md"
  ],
  "bin": {
    "sql-reactive-orm-codegen": "./src/cli/codegen.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:node": "vitest run --project node",
    "test:browser": "vitest run --project browser",
    "typecheck": "tsc --noEmit",
    "fmt": "oxfmt --write 'src/**/*.{ts,tsx}' 'test/**/*.{ts,tsx}' 'demo/src/**/*.{ts,tsx}' 'demo/orm.config.ts' 'demo/vite.config.ts' 'vitest.config.ts'",
    "fmt:check": "oxfmt --check 'src/**/*.{ts,tsx}' 'test/**/*.{ts,tsx}' 'demo/src/**/*.{ts,tsx}' 'demo/orm.config.ts' 'demo/vite.config.ts' 'vitest.config.ts'",
    "demo": "pnpm --filter money-tracker-demo dev",
    "demo:build": "pnpm --filter money-tracker-demo build",
    "demo:codegen": "pnpm --filter money-tracker-demo codegen"
  },
  "dependencies": {
    "kysely": "^0.28.16",
    "mobx": "^6.13.5"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sql.js": "^1.12.0"
  },
  "peerDependenciesMeta": {
    "sql.js": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/sql.js": "^1.4.9",
    "@vitest/browser": "^4.1.4",
    "@vitest/browser-playwright": "^4.1.4",
    "mobx-react-lite": "^4.0.7",
    "oxfmt": "^0.45.0",
    "playwright": "^1.49.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sql.js": "^1.12.0",
    "typescript": "^5.7.2",
    "vite": "^6.4.2",
    "vitest": "^4.1.4",
    "vitest-browser-react": "^2.2.0"
  }
}
